# HintGrid environment configuration
# Format: KEY=value
# Each field includes a short description, type, and example. Empty values allowed where noted.

# PostgreSQL connection
# PostgreSQL server hostname for Mastodon database. Used in data loading step.
# Type: str | Example: db.internal
HINTGRID_POSTGRES_HOST=localhost
# PostgreSQL server port.
# Type: int | Example: 5432
HINTGRID_POSTGRES_PORT=5432
# PostgreSQL database name containing Mastodon tables.
# Type: str | Example: mastodon_production
HINTGRID_POSTGRES_DATABASE=mastodon_production
# PostgreSQL username for authentication.
# Type: str | Example: mastodon
HINTGRID_POSTGRES_USER=mastodon
# PostgreSQL password. Leave empty for peer/trust auth (optional).
# Type: str | Example: s3cr3t | Optional: yes
HINTGRID_POSTGRES_PASSWORD=
# PostgreSQL schema containing Mastodon tables.
# Type: str | Example: public
HINTGRID_POSTGRES_SCHEMA=public

# Neo4j connection
# Neo4j server hostname. Graph database for social/recommendation data.
# Type: str | Example: neo4j.internal
HINTGRID_NEO4J_HOST=localhost
# Neo4j Bolt protocol port.
# Type: int | Example: 7687
HINTGRID_NEO4J_PORT=7687
# Neo4j username for authentication.
# Type: str | Example: neo4j
HINTGRID_NEO4J_USERNAME=neo4j
# Neo4j password for authentication.
# Type: str | Example: password
HINTGRID_NEO4J_PASSWORD=password
# Neo4j worker label for multi-worker isolation. Appended to node labels (optional).
# Type: str | Example: worker1 | Optional: yes
HINTGRID_NEO4J_WORKER_LABEL=

# Redis connection
# Redis server hostname. Stores ranked feeds served to Mastodon.
# Type: str | Example: redis.internal
HINTGRID_REDIS_HOST=localhost
# Redis server port.
# Type: int | Example: 6379
HINTGRID_REDIS_PORT=6379
# Redis database index (0-15).
# Type: int | Example: 0
HINTGRID_REDIS_DB=0
# Redis password (optional).
# Type: str | Example: redispass | Optional: yes
HINTGRID_REDIS_PASSWORD=
# Redis key namespace for Mastodon REDIS_NAMESPACE support. Prepended to all feed keys (optional).
# Type: str | Example: mastodon | Optional: yes
HINTGRID_REDIS_NAMESPACE=

# LLM/embeddings provider
# Embedding provider. Determines how post text is converted to vectors for similarity-based clustering.
# Type: str | Example: ollama | Values: ollama, openai, fasttext
HINTGRID_LLM_PROVIDER=ollama
# LLM API base URL. When empty, local FastText model is used instead (optional).
# Type: str | Example: http://llm:11434 | Optional: yes
HINTGRID_LLM_BASE_URL=
# LLM model name for generating embeddings.
# Type: str | Example: nomic-embed-text
HINTGRID_LLM_MODEL=nomic-embed-text
# Embedding vector dimensions for LLM providers (not FastText).
# Type: int | Example: 768
HINTGRID_LLM_DIMENSIONS=768
# LLM API request timeout in seconds.
# Type: int | Example: 30
HINTGRID_LLM_TIMEOUT=30
# Max retries for failed LLM API requests.
# Type: int | Example: 3
HINTGRID_LLM_MAX_RETRIES=3
# Texts per LLM API call. Larger = fewer calls but may exceed provider limits (OpenAI max 2048). Ignored for FastText.
# Type: int | Example: 256
HINTGRID_LLM_BATCH_SIZE=256
# API key for LLM provider (required for OpenAI) (optional).
# Type: str | Example: sk-example | Optional: yes
HINTGRID_LLM_API_KEY=

# Embedding filtering
# Minimum tokens required for a post to receive embeddings. Shorter posts are skipped.
# Type: int | Example: 1
HINTGRID_MIN_EMBEDDING_TOKENS=1
# Skip shortest posts by character length percentile (0.05 = skip bottom 5%).
# Type: float | Example: 0.0
HINTGRID_EMBEDDING_SKIP_PERCENTILE=0.0

# FastText embedding settings (for local embedding service)
# FastText embedding vector dimensions (16-1024). Used in post similarity and clustering steps.
# Type: int | Example: 128
HINTGRID_FASTTEXT_VECTOR_SIZE=128
# Context window size for FastText training.
# Type: int | Example: 3
HINTGRID_FASTTEXT_WINDOW=3
# Minimum word frequency for FastText vocabulary. Higher = more aggressive pruning for social media.
# Type: int | Example: 10
HINTGRID_FASTTEXT_MIN_COUNT=10
# Maximum vocabulary size to cap FastText memory usage.
# Type: int | Example: 500000
HINTGRID_FASTTEXT_MAX_VOCAB_SIZE=500000
# Training epochs for FastText model.
# Type: int | Example: 5
HINTGRID_FASTTEXT_EPOCHS=5
# Hash buckets for FastText subword features. Lower = less memory usage.
# Type: int | Example: 10000
HINTGRID_FASTTEXT_BUCKET=10000
# Minimum documents required before FastText training starts.
# Type: int | Example: 100
HINTGRID_FASTTEXT_MIN_DOCUMENTS=100
# Directory path for FastText model storage.
# Type: str | Example: ~/.hintgrid/models
HINTGRID_FASTTEXT_MODEL_PATH=~/.hintgrid/models
# Enable FastText model quantization (10-50x size reduction).
# Type: bool | Example: true
HINTGRID_FASTTEXT_QUANTIZE=true
# PQ subquantizers (compress-fasttext): must be <= vector_size and divide vector_size when quantize is on.
# Type: int | Example: 64
HINTGRID_FASTTEXT_QUANTIZE_QDIM=64
# CPU threads for FastText training (0 = auto-detect via os.cpu_count()).
# Type: int | Example: 0
HINTGRID_FASTTEXT_TRAINING_WORKERS=0

# Pipeline core
# Batch size for incremental data loading from PostgreSQL.
# Type: int | Example: 10000
HINTGRID_BATCH_SIZE=10000
# Load data window. Limits time-based entities to recent data. Follows/blocks always fully loaded (optional).
# Format: <number>d where d means days (e.g., 30d for last 30 days).
# Type: str | Example: 30d | Optional: yes
HINTGRID_LOAD_SINCE=90d
# Global retry count for pipeline step failures.
# Type: int | Example: 3
HINTGRID_MAX_RETRIES=3
# Records processed between checkpoint saves. Enables resume on interrupt.
# Type: int | Example: 1000
HINTGRID_CHECKPOINT_INTERVAL=1000
# Batch size for Neo4j APOC server-side batch operations.
# Type: int | Example: 10000
HINTGRID_APOC_BATCH_SIZE=10000
# Batch size for SIMILAR_TO graph build only (apoc.periodic.iterate + vector index per post).
# Lower values reduce Neo4j transaction memory; raise MemoryPoolOutOfMemoryError → decrease this or increase Neo4j transaction limits.
# Type: int | Example: 2000
HINTGRID_SIMILARITY_ITERATE_BATCH_SIZE=2000

# Concurrency
# ThreadPool workers for parallel feed generation.
# Type: int | Example: 1
HINTGRID_FEED_WORKERS=1
# ThreadPool workers for parallel entity loading from PostgreSQL.
# Type: int | Example: 1
HINTGRID_LOADER_WORKERS=1

# Communities and clustering
# User community detection strategy.
# Type: str | Example: dynamic | Values: dynamic
HINTGRID_USER_COMMUNITIES=dynamic
# Post community detection strategy.
# Type: str | Example: dynamic | Values: dynamic
HINTGRID_POST_COMMUNITIES=dynamic
# Leiden gamma for community detection. Lower = fewer, larger communities. 0.1 works well for social graphs.
# Type: float | Example: 0.1
HINTGRID_LEIDEN_RESOLUTION=0.1
# Maximum hierarchical Leiden levels for multi-level clustering.
# Type: int | Example: 10
HINTGRID_LEIDEN_MAX_LEVELS=10
# Extra Leiden / graph metrics in logs (INTERACTS_WITH or SIMILAR_TO weights, GDS communityDistribution).
# Type: bool | Example: false
HINTGRID_LEIDEN_DIAGNOSTICS=false
# Merge Leiden singleton clusters (size 1 by cluster_id) into one reserved noise community before materializing UserCommunity/PostCommunity.
# Type: bool | Example: true
HINTGRID_SINGLETON_COLLAPSE_ENABLED=true
# Reserved cluster id for merged singletons (UserCommunity.id / PostCommunity.id). Must not be 0 (used when the graph has no edges).
# Type: int | Example: -1
HINTGRID_NOISE_COMMUNITY_ID=-1
# Singleton collapse: 0 = single Cypher transaction; >0 = Neo4j 5 CALL/IN TRANSACTIONS batch size (limits memory on huge post graphs).
# Type: int | Example: 100000
HINTGRID_SINGLETON_COLLAPSE_IN_TRANSACTIONS_OF=100000
# KNN neighbors for post similarity graph construction. More = denser graph, better clustering.
# Type: int | Example: 10
HINTGRID_KNN_NEIGHBORS=10
# KNN top_k offset to exclude self-neighbor from results.
# Type: int | Example: 1
HINTGRID_KNN_SELF_NEIGHBOR_OFFSET=1
# Cosine similarity threshold for SIMILAR_TO edges. Lower = more edges, prevents fragmentation.
# Type: float | Example: 0.7
HINTGRID_SIMILARITY_THRESHOLD=0.7
# Recency window in days for SIMILAR_TO edge creation.
# Type: int | Example: 7
HINTGRID_SIMILARITY_RECENCY_DAYS=90

# Similarity pruning
# Pruning strategy for SIMILAR_TO edges after clustering.
# Values: aggressive (delete all), partial (below threshold), temporal (older than days), none
# Type: str | Example: aggressive
HINTGRID_SIMILARITY_PRUNING=aggressive
# Whether to prune SIMILAR_TO edges after clustering completes.
# Type: bool | Example: true
HINTGRID_PRUNE_AFTER_CLUSTERING=true
# Threshold for partial pruning: edges below this value are removed.
# Type: float | Example: 0.9
HINTGRID_PRUNE_SIMILARITY_THRESHOLD=0.9
# Window in days for temporal pruning strategy.
# Type: int | Example: 30
HINTGRID_PRUNE_DAYS=30

# Interest and scoring weights
# Half-life in days for exponential decay of interaction weights. Older interactions contribute less.
# Type: int | Example: 14
HINTGRID_DECAY_HALF_LIFE_DAYS=14
# TTL in days for INTERESTED_IN relationships. Expired interests are removed during analytics.
# Type: int | Example: 30
HINTGRID_INTERESTS_TTL_DAYS=30
# Minimum favourites required before building user interest profile.
# Type: int | Example: 5
HINTGRID_INTERESTS_MIN_FAVOURITES=5
# Weight for FAVORITED edges in interest calculation and INTERACTS_WITH aggregation.
# Used in SQL query: count(*) * likes_weight. Higher = likes contribute more to user interests and clustering.
# Type: float | Example: 1.0
HINTGRID_LIKES_WEIGHT=1.0
# Weight for REBLOGGED edges in interest calculation and INTERACTS_WITH aggregation.
# Used in SQL query: count(*) * reblogs_weight. Higher than likes since reblogs are stronger signals.
# Based on industry best practices (Twitter Heavy Ranker, Meta): reblogs are 3-10x more valuable than likes.
# Type: float | Example: 3.0
HINTGRID_REBLOGS_WEIGHT=3.0
# Weight for REPLIED edges in interest calculation and INTERACTS_WITH aggregation.
# Used in SQL query: count(*) * replies_weight. Highest weight since replies indicate deep engagement.
# Based on industry best practices: replies are 10-15x more valuable than likes (Twitter estimates 75x for conversations).
# Type: float | Example: 5.0
HINTGRID_REPLIES_WEIGHT=5.0
# Weight for FOLLOWS relationships when included in INTERACTS_WITH aggregation.
# Used in SQL query: each follow relationship adds follows_weight to total_weight.
# Set to 0.0 to exclude FOLLOWS from user clustering.
# Based on industry best practices: follows are 20-50x more valuable than likes as they signal long-term interest.
# Type: float | Example: 10.0
HINTGRID_FOLLOWS_WEIGHT=10.0
# Weight for mentions in INTERACTS_WITH aggregation.
# Used in SQL query: count(*) * mentions_weight. Controls how mentions contribute to user clustering.
# Based on industry best practices: mentions are 10-15x more valuable than likes, similar to replies.
# Type: float | Example: 5.0
HINTGRID_MENTIONS_WEIGHT=5.0
# Weight for bookmarked posts in interest calculation. Higher than likes.
# Type: float | Example: 2.0
HINTGRID_BOOKMARK_WEIGHT=2.0

# CTR scoring
# Enable click-through rate scoring. Uses interaction history to boost relevant posts.
# Type: bool | Example: true
HINTGRID_CTR_ENABLED=true
# CTR weight in final scoring formula (0-1).
# Type: float | Example: 0.5
HINTGRID_CTR_WEIGHT=0.5
# Minimum CTR threshold. Posts below this are not boosted by CTR.
# Type: float | Example: 0.0
HINTGRID_MIN_CTR=0.0
# CTR smoothing factor (Laplace smoothing) to handle sparse data.
# Type: float | Example: 1.0
HINTGRID_CTR_SMOOTHING=1.0

# PageRank scoring
# Enable PageRank-based author authority scoring. Boosts posts from influential users.
# Type: bool | Example: true
HINTGRID_PAGERANK_ENABLED=true
# PageRank weight in final feed score.
# Type: float | Example: 0.1
HINTGRID_PAGERANK_WEIGHT=0.1
# PageRank damping factor (0-1). Standard value is 0.85.
# Type: float | Example: 0.85
HINTGRID_PAGERANK_DAMPING_FACTOR=0.85
# Maximum iterations for PageRank convergence.
# Type: int | Example: 20
HINTGRID_PAGERANK_MAX_ITERATIONS=200

# Community similarity scoring
# Enable community-based similarity scoring for cross-community recommendations.
# Type: bool | Example: true
HINTGRID_COMMUNITY_SIMILARITY_ENABLED=true
# Top-K similar communities to consider for cross-community recommendations.
# Type: int | Example: 5
HINTGRID_COMMUNITY_SIMILARITY_TOP_K=5

# Serendipity (random discovery)
# Probability (0-1) of injecting random cross-community posts for discovery.
# Type: float | Example: 0.1
HINTGRID_SERENDIPITY_PROBABILITY=0.1
# Maximum serendipity posts per pipeline run.
# Type: int | Example: 100
HINTGRID_SERENDIPITY_LIMIT=100
# Base score assigned to serendipity posts (0-1).
# Type: float | Example: 0.1
HINTGRID_SERENDIPITY_SCORE=0.1
# based_on field value for serendipity links in the graph.
# Type: int | Example: 0
HINTGRID_SERENDIPITY_BASED_ON=0

# Feed generation
# Maximum posts per user feed.
# Type: int | Example: 500
HINTGRID_FEED_SIZE=500
# Time window in days for candidate posts.
# Type: int | Example: 7
HINTGRID_FEED_DAYS=90
# Feed TTL strategy. Non-none values currently ignored for home feeds to avoid Mastodon conflicts.
# Type: str | Example: none | Values: none, 1h, 6h, 12h, 24h, 48h, 7d
HINTGRID_FEED_TTL=none
# Score multiplier for feed ranking. Higher = HintGrid posts rank above Mastodon entries.
# Type: int | Example: 2
HINTGRID_FEED_SCORE_MULTIPLIER=2
# Decimal places for score rounding.
# Type: int | Example: 4
HINTGRID_FEED_SCORE_DECIMALS=4
# Interest component weight in personalized feed score (interest+popularity+recency must = 1.0).
# Type: float | Example: 0.5
HINTGRID_PERSONALIZED_INTEREST_WEIGHT=0.5
# Popularity component weight in personalized feed score.
# Type: float | Example: 0.3
HINTGRID_PERSONALIZED_POPULARITY_WEIGHT=0.3
# Recency component weight in personalized feed score.
# Type: float | Example: 0.2
HINTGRID_PERSONALIZED_RECENCY_WEIGHT=0.2
# Popularity weight for cold start scoring (no user history; popularity+recency must = 1.0).
# Type: float | Example: 0.7
HINTGRID_COLD_START_POPULARITY_WEIGHT=0.7
# Recency weight for cold start scoring.
# Type: float | Example: 0.3
HINTGRID_COLD_START_RECENCY_WEIGHT=0.3
# Smoothing factor for popularity score calculation (must be > 0).
# Type: float | Example: 1.0
HINTGRID_POPULARITY_SMOOTHING=1
# Smoothing term added to post age (in days) in recency score; must be > 0.
# Type: float | Example: 0.8
HINTGRID_RECENCY_SMOOTHING=1
# Numerator for recency decay formula: score = numerator / (age + smoothing).
# Type: float | Example: 1.0
HINTGRID_RECENCY_NUMERATOR=1.0
# Cold start strategy for users with no interaction history.
# Type: str | Example: global_top | Values: global_top, recent, random
HINTGRID_COLD_START_FALLBACK=global_top
# Maximum posts for cold start users.
# Type: int | Example: 500
HINTGRID_COLD_START_LIMIT=500
# Days of inactivity before a user is considered inactive (skips feed generation).
# Type: int | Example: 90
HINTGRID_ACTIVE_USER_DAYS=90
# Force refresh all user feeds even if recently updated.
# Type: bool | Example: false
HINTGRID_FEED_FORCE_REFRESH=false
# Weight boost for posts matching chosen_languages (not UI locale) in feed scoring.
# Type: float | Example: 0.3
HINTGRID_LANGUAGE_MATCH_WEIGHT=0.3
# Weight boost when post language matches user's UI locale (users.locale).
# Must be >= HINTGRID_LANGUAGE_MATCH_WEIGHT.
# Type: float | Example: 0.5
HINTGRID_UI_LANGUAGE_MATCH_WEIGHT=0.5

# Public timelines
# Maximum posts in public timeline feeds. Mastodon default is 400.
# Type: int | Example: 400
HINTGRID_PUBLIC_FEED_SIZE=400
# Enable filling public timelines (timeline:public, timeline:public:local).
# Type: bool | Example: true
HINTGRID_PUBLIC_FEED_ENABLED=true
# Public feed post selection strategy.
# Type: str | Example: local_communities | Values: all_communities, local_communities
HINTGRID_PUBLIC_FEED_STRATEGY=local_communities
# Redis key pattern for the public timeline.
# Type: str | Example: timeline:public
HINTGRID_PUBLIC_TIMELINE_KEY=timeline:public
# Redis key pattern for local public timeline.
# Type: str | Example: timeline:public:local
HINTGRID_LOCAL_TIMELINE_KEY=timeline:public:local

# Export settings
# Maximum items per feed in Markdown export output.
# Type: int | Example: 50
HINTGRID_EXPORT_MAX_ITEMS=50
# Character limit for text preview in export.
# Type: int | Example: 60
HINTGRID_TEXT_PREVIEW_LIMIT=60
# Max interests displayed per community in export.
# Type: int | Example: 30
HINTGRID_COMMUNITY_INTEREST_LIMIT=30
# Sample size for community member list in export.
# Type: int | Example: 5
HINTGRID_COMMUNITY_MEMBER_SAMPLE=5
# Max communities shown in export output.
# Type: int | Example: 5
HINTGRID_COMMUNITY_SAMPLE_LIMIT=5
# Max graph elements in Mermaid diagrams in export.
# Type: int | Example: 10
HINTGRID_GRAPH_SAMPLE_LIMIT=10

# Database client tuning
# Minimum connections in PostgreSQL connection pool.
# Type: int | Example: 1
HINTGRID_PG_POOL_MIN_SIZE=1
# Maximum connections in PostgreSQL pool. Higher = more parallel loading.
# Type: int | Example: 5
HINTGRID_PG_POOL_MAX_SIZE=5
# Timeout in seconds for acquiring a pool connection.
# Type: int | Example: 30
HINTGRID_PG_POOL_TIMEOUT_SECONDS=30
# Number of retries when waiting for Neo4j readiness at startup.
# Type: int | Example: 30
HINTGRID_NEO4J_READY_RETRIES=30
# Sleep duration in seconds between Neo4j readiness checks.
# Type: int | Example: 1
HINTGRID_NEO4J_READY_SLEEP_SECONDS=1
# Score comparison tolerance for feed deduplication in Redis.
# Type: float | Example: 1e-06
HINTGRID_REDIS_SCORE_TOLERANCE=1e-06

# Mastodon integration
# Mastodon visibility level filter for public statuses (0=public).
# Type: int | Example: 0
HINTGRID_MASTODON_PUBLIC_VISIBILITY=0
# Max accounts per PostgreSQL lookup query.
# Type: int | Example: 1
HINTGRID_MASTODON_ACCOUNT_LOOKUP_LIMIT=1

# Logging
# Logging verbosity level.
# Type: str | Example: INFO | Values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Note: Use CLI flag --verbose (-v) for debug output with full stack traces.
HINTGRID_LOG_LEVEL=INFO
# Log file path for persistent logging output.
# Type: str | Example: hintgrid.log
HINTGRID_LOG_FILE=hintgrid.log
# Progress UI: auto uses TTY detection (plain line-based logs when not a terminal, e.g. systemd).
# Type: str | Example: auto | Values: auto, rich, plain
HINTGRID_PROGRESS_OUTPUT=auto
# Seconds between Neo4j ProgressTracker polls during apoc.periodic.iterate progress UI.
# Type: float | Example: 0.5 | Range: (0, 300]
HINTGRID_PROGRESS_POLL_INTERVAL_SECONDS=0.5

# Note: The --verbose (-v) CLI flag is available for debugging.
# It sets LOG_LEVEL=DEBUG and shows full stack traces on errors.
# This flag has no environment variable equivalent (CLI-only).
